{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/coffee-recipe-generator/scripts/validate-recipe-output.py\"",
            "timeout": 10,
            "statusMessage": "Validating coffee recipe output"
          }
        ]
      }
    ]
  }
}
